# Production cache headers (Netlify / Cloudflare Pages).
# HTML is intentionally omitted so it keeps the host default (revalidated),
# letting content and _redirects changes propagate immediately.

# Images, video, and self-hosted fonts under /assets: long cache, revalidated
# on replace (filenames are not content-hashed).
/assets/*
  Cache-Control: public, max-age=2592000

/favicon.svg
  Cache-Control: public, max-age=2592000

# Root CSS/JS are query-versioned (?v=...), so a given URL never changes.
/site.css
  Cache-Control: public, max-age=31536000, immutable
/menu-fix.css
  Cache-Control: public, max-age=31536000, immutable
/menu-fix.js
  Cache-Control: public, max-age=31536000, immutable
/cms-connect.js
  Cache-Control: public, max-age=31536000, immutable
/career-detail.css
  Cache-Control: public, max-age=31536000, immutable
/career-detail.js
  Cache-Control: public, max-age=31536000, immutable
/reveal.js
  Cache-Control: public, max-age=31536000, immutable
/hero-anim.js
  Cache-Control: public, max-age=31536000, immutable
